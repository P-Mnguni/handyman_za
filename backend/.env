# SMS (Twilio - South Afrcan based)
TWILIO_ACCOUNT_SID=AC_test_account_sid
TWILIO_AUTH_TOKEN=test_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# -------------------------------------------------------------
# 6️⃣ FILE UPLOADS (Handyman Verification Docs)
# -------------------------------------------------------------
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=123456789012345
CLOUDINARY_API_SECRET=your_cloudinary_secret
MAX_FILE_SIZE=5242880                               # 5MB in bytes
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/webp,application/pdf

# -------------------------------------------------------------
# 7️⃣ RATE LIMITING & CACHING
# -------------------------------------------------------------
REDIS_URL=redis://localhost:6379
RATE_LIMIT_WINDOW_MS=900000                         # 15 minutes
RATE_LIMIT_MAX_REQUESTS=100                         # per IP per window

# -------------------------------------------------------------
# 8️⃣ FRONTEND & CORS SETTINGS
# -------------------------------------------------------------
FRONTEND_URL=http://localhost:3000
ADMIN_URL=http://localhost:3001
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# -------------------------------------------------------------
# 9️⃣ MONITORING & LOGGING
# -------------------------------------------------------------
SENTRY_DSN=https://test@sentry.io/1234567
LOG_LEVEL=info
LOG_TO_FILE=true

# -------------------------------------------------------------
# 🔟 BUSINESS LOGIC CONFIGURATION
# -------------------------------------------------------------
# Job Matching
MAX_RADIUS_KM=50
JOB_REQUEST_TIMEOUT_MINUTES=30                      # How long handymen have to respond
MAX_HANDYMEN_PER_JOB=10                             # How many handymen to notify

# Platform
SUPPORT_PHONE=+27123456789
SUPPORT_EMAIL=support@handyman.za
TERMS_URL=https://handyman.za/terms
PRIVACY_URL=https://handyman.za/privacy

# -------------------------------------------------------------
# 🔒 SECURITY HEADEERS & TIMEOUTS
# -------------------------------------------------------------
SESSION_TIMEOUT_MINUTES=30
PASSWORD_RESET_TIMEOUT_MINUTES=15
VERIFICATION_CODE_EXPIRY_MINUTES=10

# -------------------------------------------------------------
# 🚀 FEATURE FLAGS (Enable/Disable Features)
# -------------------------------------------------------------
FEATURE_PAYMENTS=true
FEATURE_REAL_TIME=true
FEATURE_SMS_NOTIFICATION=false
FEATURE_EMAIL_VERIFICATION=true
FEATURE_HANDYMAN_VERIFICATION=true
FEATURE_ADVANCED_JOB_MATCHING=true