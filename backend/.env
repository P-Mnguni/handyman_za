# Platform Commission (Percentage)
PLATFORM_COMMISSION_PERCENT=15

# ---------------------------------------------------------------
# 5️⃣ EMAIL & NOTIFICATIONS
# ---------------------------------------------------------------
EMAIL_PROVIDER=console                  # console, sendgrid, or resend
