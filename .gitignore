# ====================================================================
# 🛠️ Handyman.za - Git Ignore Rules
# ====================================================================

# DO NOT commit sensitive files to version control

# --------------------------------------------------------------------
# 1️⃣ ENVIRONMENT & CONFIGURATION FILES
# --------------------------------------------------------------------
.env 
.env.local
.env.development
.env.production
.env.test
.env.*.local
.env.example
config/local.*
secrets/

# --------------------------------------------------------------------
# 2️⃣ DEPENDEnCIES & BUILD ARTIFACTS
# --------------------------------------------------------------------
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnp*
.pnp.js
package-lock.json
yarn.lock

# --------------------------------------------------------------------
# 3️⃣ RUNTIME & LOG FILES
# --------------------------------------------------------------------
logs/
*.log
*.pid
*.pid.lock

# --------------------------------------------------------------------
# 4️⃣ DEVELOPMENT & IDE FILES
# --------------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*-
.DS_Store
Thumbs.db

# --------------------------------------------------------------------
# 5️⃣ UPLOADS & USER-GENERATED CONTENT
# --------------------------------------------------------------------
uploads/
temp/
storage/
public/uploads/
public/temp/

# --------------------------------------------------------------------
# 6️⃣ TEST & COVERAGE REPORTS
# --------------------------------------------------------------------
coverage/
.nyc_output/

# --------------------------------------------------------------------
# 7️⃣ OPERATING SYSTEM FILES
# --------------------------------------------------------------------
# macOS
.DS_Store
.AppleDouble
.LSOverride

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini

# Linux
*-

# -------------------------------------------------------------------
# 8️⃣ CERTIFICATES & SECRET KEYS
# -------------------------------------------------------------------
*.pem
*.KEYS
*.crt
*.cer
*.pub
*.secret
*.private

# -------------------------------------------------------------------
# 9️⃣ DOCKER & DEPLOYMENT
# -------------------------------------------------------------------
.docker/
.dockerignore
docker-compose.override.yml

# -------------------------------------------------------------------
# 🔟 TEMPORARY & CACHE FILES
# -------------------------------------------------------------------
.cache/
.tmp/
tmp/